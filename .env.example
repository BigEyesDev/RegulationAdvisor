# ── LLM Providers ─────────────────────────────────────────────
# Leave ALL FIVE of these blank to run BYOK-only: visitors without their
# own key get a clear "bring your own key" message instead of a call
# billed to whoever deployed this. Set the one matching LLM_PROVIDER below
# to fund a shared default that works with zero setup for visitors.

# Get free key at: console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get free key at: aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# Get free key at: openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Get key at: platform.openai.com (also used by the RAGAS eval harness)
OPENAI_API_KEY=your_openai_api_key_here

# Get key at: console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Web Search ─────────────────────────────────────────────────
# Get free key at: tavily.com (1000 req/month free)
TAVILY_API_KEY=your_tavily_api_key_here

# ── HuggingFace ────────────────────────────────────────────────
# Get at: huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your_hf_token_here

# ── Model Config ───────────────────────────────────────────────
LLM_PROVIDER=groq
LLM_MODEL=qwen/qwen3-32b

# ── Embedding Model (local, no API needed) ─────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Retrieval ──────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=5

# ── Vector Store ───────────────────────────────────────────────
# Week 1-3: use "faiss"
# Week 4+:  use "chromadb"
VECTOR_STORE_BACKEND=faiss
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Evaluation endpoint ──────────────────────────────────────────
# POST /api/evaluate runs the full RAGAS QA set with no per-caller key check —
# leave disabled unless this API isn't public, or you accept the cost/abuse
# risk. Evaluations otherwise run locally via scripts/run_evaluation.py.
ENABLE_EVALUATE_ENDPOINT=false
